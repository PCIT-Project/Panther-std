def std = @import("std");



//////////////////////////////////////////////////////////////////////
// array reference


impl [$$:*] #builtin("arrayRef.IterableRef") {
	createIterator = (this) -> impl(std.ArrayRefIter<{This}>:std.Iterator) {
		return new impl(std.ArrayRefIter<{This}>:std.Iterator)(this);
	},
}

impl [$$:*] #builtin("arrayRef.IterableRefRT") {
	createIterator = (this) -> impl(std.ArrayRefIter<{This}>:std.IteratorRT) {
		return new impl(std.ArrayRefIter<{This}>:std.IteratorRT)(this);
	},
}


//////////////////////////////////////////////////////////////////////
// mutable array reference

impl [$$:*mut] #builtin("arrayMutRef.IterableMutRef") {
	createIterator = (this) -> impl(std.MutArrayRefIter<{This}>:std.MutIterator) {
		return new impl(std.MutArrayRefIter<{This}>:std.MutIterator)(this);
	},
}

impl [$$:*mut] #builtin("arrayMutRef.IterableMutRefRT") {
	createIterator = (this) -> impl(std.MutArrayRefIter<{This}>:std.MutIteratorRT) {
		return new impl(std.MutArrayRefIter<{This}>:std.MutIteratorRT)(this);
	},
}




//////////////////////////////////////////////////////////////////////
// array iter


impl [$$:$$] #builtin("array.Iterable") {
	createIterator = (this) -> impl(std.ArrayRefIter<{[type(@arrayElementTypeID<{This}>()):*]}>:std.Iterator) {
		return new impl(std.ArrayRefIter<{[type(@arrayElementTypeID<{This}>()):*]}>:std.Iterator)(
			this as [type(@arrayElementTypeID<{This}>()):*]
		);
	},

	createIterator = (this mut)
	-> impl(std.MutArrayRefIter<{[type(@arrayElementTypeID<{This}>()):*mut]}>:std.MutIterator) {
		return new impl(std.MutArrayRefIter<{[type(@arrayElementTypeID<{This}>()):*mut]}>:std.MutIterator)(
			this as [type(@arrayElementTypeID<{This}>()):*mut]
		);
	},
}


impl [$$:$$] #builtin("array.IterableRT") {
	createIterator = (this) -> impl(std.ArrayRefIter<{[type(@arrayElementTypeID<{This}>()):*]}>:std.IteratorRT) {
		return new impl(std.ArrayRefIter<{[type(@arrayElementTypeID<{This}>()):*]}>:std.IteratorRT)(
			this as [type(@arrayElementTypeID<{This}>()):*]
		);
	},

	createIterator = (this mut)
	-> impl(std.MutArrayRefIter<{[type(@arrayElementTypeID<{This}>()):*mut]}>:std.MutIteratorRT) {
		return new impl(std.MutArrayRefIter<{[type(@arrayElementTypeID<{This}>()):*mut]}>:std.MutIteratorRT)(
			this as [type(@arrayElementTypeID<{This}>()):*mut]
		);
	},
}
